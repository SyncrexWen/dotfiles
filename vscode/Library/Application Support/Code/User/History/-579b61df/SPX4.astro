---
/**
 * @file Callout.astro
 * @description A customizable callout block for Markdoc, used to highlight important information, warnings, or tips.
 */

export interface Props {
    /**
     * The style type of the callout.
     * @default 'info'
     */
    type?: 'info' | 'tip' | 'warning' | 'danger';
    /**
     * An optional title for the callout box.
     */
    title?: string;
}

const { type = 'info', title } = Astro.props;

const iconMap = {
    info: 'ℹ️',
    tip: '💡',
    warning: '⚠️',
    danger: '🚨',
};
---

<aside class={`callout callout-${type}`}>
    <div class="callout-icon">{iconMap[type]}</div>
    <div class="callout-inner">
        {title && <div class="callout-title">{title}</div>}
        <div class="callout-content">
            <slot />
        </div>
    </div>
</aside>

<style>
    .callout {
        display: flex;
        align-items: flex-start;
        padding: 1.25rem;
        margin: 1.5rem 0;
        border-radius: 8px;
        border-left: 4px solid;
        background-color: #f8fafc; /* Match your IllustrateBox header background */
        color: #4a5568;
        line-height: 1.6;
    }

    .callout-icon {
        font-size: 1.25rem;
        margin-right: 1rem;
        flex-shrink: 0;
        line-height: 1.4; /* Align icon nicely with title/text */
    }

    .callout-inner {
        flex-grow: 1;
    }

    .callout-title {
        font-weight: 700;
        color: #1a202c;
        margin-bottom: 0.5rem;
        font-size: 1.05rem;
    }

    /* Target injected markdown paragraphs to fix margins */
    .callout-content :global(p:first-child) {
        margin-top: 0;
    }
    .callout-content :global(p:last-child) {
        margin-bottom: 0;
    }

    /* --- Theme Colors --- */
    .callout-info {
        border-left-color: #3b82f6; /* Blue */
        background-color: #eff6ff;
    }
    .callout-tip {
        border-left-color: #10b981; /* Green */
        background-color: #ecfdf5;
    }
    .callout-warning {
        border-left-color: #f59e0b; /* Yellow/Orange */
        background-color: #fffbeb;
    }
    .callout-danger {
        border-left-color: #ef4444; /* Red */
        background-color: #fef2f2;
    }
</style>
